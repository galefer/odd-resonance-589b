---
import gravetaleLogo from '../assets/gravetale_logo.png';
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>GRAVETALE Studios™</title>

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link
      href="https://fonts.googleapis.com/css2?family=IM+Fell+Great+Primer+SC&family=Roboto+Mono:wght@400;500;700&family=Inter:wght@400;500;600&display=swap"
      rel="stylesheet"
    >

    <style>
      :root {
        --accent: #a32000;
        --accent-bright: #e34646;
        --accent-rgba: 163, 32, 0;
        --bg-dark: #070707;
        --bg-soft: #0d0d0d;
        --text-main: #d7d7d7;
        --text-dim: #9f9f9f;
        --line: rgba(163, 32, 0, 0.22);
      }

      * {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
      }

      html,
      body {
        min-height: 100%;
      }

      body {
        font-family: 'Inter', sans-serif;
        background:
          radial-gradient(circle at top, rgba(163, 32, 0, 0.14), transparent 35%),
          linear-gradient(to bottom, #050505 0%, #090909 45%, #050505 100%);
        color: var(--text-main);
        overflow-x: hidden;
      }

      a {
        color: inherit;
        text-decoration: none;
      }

      .grain {
        position: fixed;
        inset: 0;
        pointer-events: none;
        z-index: 20;
        opacity: 0.045;
        background-image:
          radial-gradient(rgba(255,255,255,0.16) 0.45px, transparent 0.45px);
        background-size: 4px 4px;
        mix-blend-mode: soft-light;
      }

      .scanlines {
        position: fixed;
        inset: 0;
        pointer-events: none;
        z-index: 19;
        opacity: 0.08;
        background: repeating-linear-gradient(
          to bottom,
          rgba(255,255,255,0.035) 0px,
          rgba(255,255,255,0.035) 1px,
          transparent 2px,
          transparent 4px
        );
      }

      .page-shell {
        position: relative;
        min-height: 100vh;
        display: flex;
        flex-direction: column;
      }

      .site-header {
        position: relative;
        z-index: 10;
        width: 100%;
        border-bottom: 1px solid var(--line);
        background: rgba(0, 0, 0, 0.55);
        backdrop-filter: blur(6px);
      }

      .site-header-inner {
        width: min(1200px, calc(100% - 2rem));
        margin: 0 auto;
        min-height: 74px;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 1rem;
      }

      .brand-mark {
        display: flex;
        align-items: center;
        gap: 0.9rem;
      }

      .brand-mark img {
        width: 46px;
        height: 46px;
        object-fit: contain;
        filter: drop-shadow(0 0 10px rgba(163, 32, 0, 0.18));
      }

      .brand-text {
        display: flex;
        flex-direction: column;
        gap: 0.15rem;
      }

      .brand-text strong {
        font-family: 'IM Fell Great Primer SC', serif;
        font-size: 1.15rem;
        letter-spacing: 2px;
        color: var(--accent);
        text-shadow: 0 0 10px rgba(163, 32, 0, 0.22);
      }

      .brand-text span {
        font-family: 'Roboto Mono', monospace;
        font-size: 0.72rem;
        letter-spacing: 1.6px;
        text-transform: uppercase;
        color: var(--text-dim);
      }

      .header-links {
        display: flex;
        align-items: center;
        gap: 1rem;
      }

      .header-links a {
        font-family: 'Roboto Mono', monospace;
        font-size: 0.82rem;
        text-transform: uppercase;
        letter-spacing: 1.2px;
        color: #c9c9c9;
        transition: color 0.25s ease, text-shadow 0.25s ease;
      }

      .header-links a:hover {
        color: var(--accent-bright);
        text-shadow: 0 0 8px rgba(227, 70, 70, 0.45);
      }

      .hero {
        position: relative;
        flex: 1;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 4rem 1.25rem;
      }

      .hero::before {
        content: "";
        position: absolute;
        inset: 0;
        background:
          radial-gradient(circle at center, rgba(163, 32, 0, 0.08), transparent 42%),
          linear-gradient(to bottom, rgba(0,0,0,0.18), rgba(0,0,0,0.72));
        pointer-events: none;
      }

      .hero-panel {
        position: relative;
        z-index: 5;
        width: min(1120px, 100%);
        min-height: 70vh;
        display: grid;
        grid-template-columns: 1.1fr 0.9fr;
        overflow: hidden;
        border: 1px solid rgba(163, 32, 0, 0.24);
        border-radius: 14px;
        background:
          linear-gradient(180deg, rgba(18,18,18,0.92), rgba(8,8,8,0.98));
        box-shadow:
          0 0 0 1px rgba(255,255,255,0.02) inset,
          0 30px 80px rgba(0,0,0,0.55),
          0 0 28px rgba(163, 32, 0, 0.08);
      }

      .hero-copy {
        position: relative;
        padding: clamp(2rem, 5vw, 4.5rem);
        display: flex;
        flex-direction: column;
        justify-content: center;
      }

      .kicker {
        display: inline-flex;
        align-items: center;
        width: fit-content;
        margin-bottom: 1rem;
        padding: 0.35rem 0.75rem;
        border-radius: 999px;
        border: 1px solid rgba(163, 32, 0, 0.22);
        background: rgba(163, 32, 0, 0.08);
        font-family: 'Roboto Mono', monospace;
        font-size: 0.72rem;
        letter-spacing: 1.6px;
        text-transform: uppercase;
        color: var(--accent-bright);
      }

      .hero h1 {
        font-family: 'IM Fell Great Primer SC', serif;
        font-size: clamp(2.8rem, 7vw, 5.6rem);
        line-height: 0.95;
        letter-spacing: 2px;
        color: #f1e5e5;
        text-shadow:
          0 0 16px rgba(163, 32, 0, 0.15),
          0 0 28px rgba(0, 0, 0, 0.5);
        margin-bottom: 1rem;
      }

      .hero h1 span {
        display: block;
        color: var(--accent);
      }

      .hero p {
        max-width: 620px;
        font-size: 1.02rem;
        line-height: 1.8;
        color: #c7c7c7;
        margin-bottom: 1.7rem;
      }

      .hero-actions {
        display: flex;
        flex-wrap: wrap;
        gap: 0.9rem;
        margin-bottom: 1.5rem;
      }

      .btn-primary,
      .btn-secondary {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-height: 48px;
        padding: 0.85rem 1.3rem;
        border-radius: 8px;
        font-family: 'Roboto Mono', monospace;
        font-size: 0.86rem;
        text-transform: uppercase;
        letter-spacing: 1.2px;
        transition:
          transform 0.2s ease,
          border-color 0.2s ease,
          background 0.2s ease,
          color 0.2s ease,
          box-shadow 0.2s ease;
      }

      .btn-primary {
        background: linear-gradient(180deg, rgba(163,32,0,0.95), rgba(110,16,0,0.95));
        border: 1px solid rgba(227, 70, 70, 0.42);
        color: white;
        box-shadow: 0 0 18px rgba(163, 32, 0, 0.18);
      }

      .btn-primary:hover {
        transform: translateY(-1px);
        background: linear-gradient(180deg, rgba(184,40,0,1), rgba(122,18,0,1));
        box-shadow: 0 0 22px rgba(227, 70, 70, 0.2);
      }

      .btn-secondary {
        border: 1px solid rgba(163, 32, 0, 0.22);
        background: rgba(255,255,255,0.025);
        color: #d6d6d6;
      }

      .btn-secondary:hover {
        transform: translateY(-1px);
        border-color: rgba(227, 70, 70, 0.34);
        color: var(--accent-bright);
        box-shadow: 0 0 14px rgba(163, 32, 0, 0.08);
      }

      .hero-meta {
        display: flex;
        flex-wrap: wrap;
        gap: 0.7rem;
      }

      .meta-pill {
        padding: 0.45rem 0.7rem;
        border-radius: 999px;
        background: rgba(255,255,255,0.03);
        border: 1px solid rgba(163, 32, 0, 0.14);
        color: #aaaaaa;
        font-family: 'Roboto Mono', monospace;
        font-size: 0.74rem;
        letter-spacing: 0.8px;
      }

      .hero-visual {
        position: relative;
        min-height: 420px;
        background:
          radial-gradient(circle at 50% 40%, rgba(163,32,0,0.2), transparent 30%),
          linear-gradient(to bottom, rgba(25,0,0,0.26), rgba(0,0,0,0.82)),
          url('/outworld/assets/images/hero.png') center center / cover no-repeat;
      }

      .hero-visual::before {
        content: "";
        position: absolute;
        inset: 0;
        background:
          linear-gradient(to right, rgba(8,8,8,0.95), rgba(8,8,8,0.15) 35%, rgba(0,0,0,0.55)),
          radial-gradient(circle at center, transparent 45%, rgba(0,0,0,0.38));
      }

      .visual-caption {
        position: absolute;
        left: 1.25rem;
        right: 1.25rem;
        bottom: 1.25rem;
        z-index: 2;
        padding: 0.9rem 1rem;
        border-radius: 8px;
        background: rgba(8,8,8,0.64);
        border: 1px solid rgba(163, 32, 0, 0.16);
        backdrop-filter: blur(4px);
      }

      .visual-caption strong {
        display: block;
        font-family: 'Roboto Mono', monospace;
        font-size: 0.76rem;
        letter-spacing: 1.4px;
        text-transform: uppercase;
        color: var(--accent-bright);
        margin-bottom: 0.4rem;
      }

      .visual-caption p {
        margin: 0;
        font-size: 0.92rem;
        line-height: 1.65;
        color: #c2c2c2;
      }

      .site-footer {
        position: relative;
        z-index: 10;
        border-top: 1px solid var(--line);
        background: rgba(0,0,0,0.55);
      }

      .site-footer-inner {
        width: min(1200px, calc(100% - 2rem));
        margin: 0 auto;
        padding: 1rem 0;
        display: flex;
        justify-content: space-between;
        gap: 1rem;
        flex-wrap: wrap;
        color: #8d8d8d;
        font-family: 'Roboto Mono', monospace;
        font-size: 0.76rem;
        letter-spacing: 1px;
        text-transform: uppercase;
      }

      @media (max-width: 900px) {
        .hero-panel {
          grid-template-columns: 1fr;
        }

        .hero-visual {
          min-height: 260px;
          order: -1;
        }

        .hero-copy {
          padding: 2rem 1.25rem 2.2rem;
        }

        .site-header-inner {
          min-height: 68px;
        }

        .brand-text strong {
          font-size: 1rem;
        }

        .header-links {
          gap: 0.75rem;
        }

        .header-links a {
          font-size: 0.74rem;
        }
      }

      @media (max-width: 640px) {
        .site-header-inner {
          width: min(100%, calc(100% - 1rem));
        }

        .brand-mark {
          gap: 0.7rem;
        }

        .brand-mark img {
          width: 40px;
          height: 40px;
        }

        .brand-text span {
          display: none;
        }

        .header-links {
          gap: 0.65rem;
        }

        .hero {
          padding: 1rem 0.75rem 2rem;
        }

        .hero h1 {
          font-size: clamp(2.3rem, 12vw, 4rem);
        }

        .hero p {
          font-size: 0.96rem;
        }

        .hero-actions {
          flex-direction: column;
          align-items: stretch;
        }

        .btn-primary,
        .btn-secondary {
          width: 100%;
        }

        .site-footer-inner {
          font-size: 0.68rem;
        }
      }
    </style>
  </head>

  <body>
    <div class="grain"></div>
    <div class="scanlines"></div>

    <div class="page-shell">
      <header class="site-header">
        <div class="site-header-inner">
          <a href="/" class="brand-mark" aria-label="GRAVETALE Studios home">
            <img src={gravetaleLogo.src} alt="GRAVETALE Studios logo" />
            <div class="brand-text">
              <strong>GRAVETALE Studios</strong>
              <span>Independent worlds. Darker visions.</span>
            </div>
          </a>

          <nav class="header-links" aria-label="Primary">
            <a href="/outworld">Outworld</a>
            <a href="https://discord.gg/5wpKBRCrAV" target="_blank" rel="noreferrer">Discord</a>
          </nav>
        </div>
      </header>

      <main class="hero">
        <section class="hero-panel">
          <div class="hero-copy">
            <div class="kicker">Now entering primary project</div>

            <h1>
              Enter
              <span>Outworld</span>
            </h1>

            <p>
              GRAVETALE Studios is currently focused on a single descent.
              Explore the archive, step into the world, and follow the path into
              survival, memory, decay, and rebirth.
            </p>

            <div class="hero-actions">
              <a href="/outworld" class="btn-primary">Enter Outworld</a>
              <a
                href="https://discord.gg/5wpKBRCrAV"
                class="btn-secondary"
                target="_blank"
                rel="noreferrer"
              >
                Join Discord
              </a>
            </div>

            <div class="hero-meta">
              <div class="meta-pill">Project: Outworld</div>
              <div class="meta-pill">Setting: Dark fantasy / existential horror</div>
              <div class="meta-pill">Studio: GRAVETALE</div>
            </div>
          </div>

          <div class="hero-visual" aria-hidden="true">
            <div class="visual-caption">
              <strong>Archive access</strong>
              <p>
                The current studio gateway points directly toward Outworld while it
                stands as the main active project.
              </p>
            </div>
          </div>
        </section>
      </main>

      <footer class="site-footer">
        <div class="site-footer-inner">
          <span>GRAVETALE Studios</span>
          <span>Outworld archive live at gravetalestudios.com/outworld</span>
        </div>
      </footer>
    </div>
  </body>
</html>